  "schema:version": "1",
  "schema:description": "Data and raw sequence files from aquatic eDNA samples collected from 2018-2022 across the Chagos Archipelago. Four markers were used for metabarcoding, targeting eukaryotic communities (18S and COI), fish and elasmobranchs (12S) and microbes (16S).",
  "schema:keywords": [
    "Earth and Environmental Sciences",
    "eDNA metabarcoding",
    "biodiversity",
    "fish & elasmobranch communities",
    "fish",
    "elasmobranch",
    "eukaryotic biodiversity",
    "microbial communities"
