  "schema:alternateName": "gov.noaa.nodc:GHRSST-MUR-JPL-L4-GLOB",
  "schema:creator": {
    "@list": [
      {
        "@type": [
          "schema:Organization"
        ],
        "schema:name": "US NASA Jet Propulsion Laboratory Physical Oceanography Distributed Active Archive Center (JPL PO.DAAC)",
        "schema:url": "https://ror.org/027k65916"
