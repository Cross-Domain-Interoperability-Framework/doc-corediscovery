  "schema:datePublished": "2017-01-16",
  "schema:dateModified": "2023-09-28",
  "schema:version": "2",
  "schema:description": "Small Area and Administrative Data are derived from the annual tax file provided by Canada Revenue Agency. From the income tax forms submitted each year by Canadians, a wealth of economic and demographic information is available. Files include data on Families, Labour Income, Economic Dependency, Seniors, RRSP Contributions and Neighbourhood Income and Demographics. Geographic coverage is by Nation, Province/Territory, Postal Area and by Census Metropolitan Area (CMA).",
  "schema:keywords": [
    "Social Sciences",
    "Business and Financial",
    "Age",
    "Contributions",
    "Dependency",
    "Family type",
    "Gender",
    "Income",
    "Investment",
    "Marital status",
    "Room",
    "Seniors",
    "Tax",
    "Transfers"
  ],
  "schema:temporalCoverage": [
    "1989/2011"
  ],
