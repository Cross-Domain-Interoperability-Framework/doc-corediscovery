@prefix cdifd: <https://cdif.org/validation/0.1/shacl#> .
@prefix dcat: <http://www.w3.org/ns/dcat#> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix dqv: <http://www.w3.org/ns/dqv#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix schema: <http://schema.org/> .
@prefix sh: <http://www.w3.org/ns/shacl#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix spdx: <http://spdx.org/rdf/terms#> .
@prefix time: <http://www.w3.org/2006/time#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<http://science-on-schema.org/1.2.3/validation/shacl#DatasetNS1Shape> a sh:NodeShape ;
    sh:message "Expecting SO namespace of <http://schema.org/> not <http://schema.org>" ;
    sh:not [ sh:minCount 1 ;
            sh:path rdf:type ] ;
    sh:targetClass <http://schema.orgDataset/> .

<http://science-on-schema.org/1.2.3/validation/shacl#DatasetNS2Shape> a sh:NodeShape ;
    sh:message "Expecting SO namespace of <http://schema.org/> not <https://schema.org/>" ;
    sh:not [ sh:minCount 1 ;
            sh:path rdf:type ] ;
    sh:targetClass <https://schema.org/Dataset> .

<http://science-on-schema.org/1.2.3/validation/shacl#DatasetNS3Shape> a sh:NodeShape ;
    sh:message "Expecting SO namespace of <http://schema.org/> not <https://schema.org>" ;
    sh:not [ sh:minCount 1 ;
            sh:path rdf:type ] ;
    sh:targetClass <https://schema.orgDataset/> .

cdifd:CDIFActionShape a sh:NodeShape ;
    sh:property [ sh:class schema:EntryPoint ;
            sh:minCount 1 ;
            sh:path schema:target ;
            sh:property [ sh:datatype xsd:string ;
                    sh:path schema:contentType ],
                [ sh:datatype xsd:string ;
                    sh:message "A web service distribution must include a URL; the CDIF schema allows URL Templates" ;
                    sh:minCount 1 ;
                    sh:path schema:urlTemplate ],
                [ sh:datatype xsd:string ;
                    sh:path schema:httpMethod ] ],
        [ sh:class schema:PropertyValueSpecification ;
            sh:path schema:query-input ;
            sh:property [ sh:datatype xsd:string ;
                    sh:message "if a URL template has query parameters, match the parameter name in this field and provide a description" ;
                    sh:minCount 1 ;
                    sh:path schema:valueName ],
                [ sh:datatype xsd:string ;
                    sh:message "provide a description for the query parameter" ;
                    sh:minCount 1 ;
                    sh:path schema:description ],
                [ sh:datatype xsd:boolean ;
                    sh:message "valueRequired is specified by a boolean (not a string) value, either 'true' or 'false'" ;
                    sh:path schema:valueRequired ] ] ;
    sh:target [ a sh:SPARQLTarget ;
            sh:select """\r
            PREFIX schema: <http://schema.org/>\r
            PREFIX prov: <http://www.w3.org/ns/prov#>\r
            SELECT ?this WHERE {\r
                ?this a ?type .\r
                FILTER (?type IN (\r
                    schema:Action, schema:AssessAction, schema:ConsumeAction,\r
                    schema:ControlAction, schema:CreateAction, schema:FindAction,\r
                    schema:InteractAction, schema:MoveAction, schema:PlayAction, schema:SearchAction,\r
                    schema:DeleteAction, schema:TransferAction, schema:UpdateAction\r
                ))\r
                FILTER NOT EXISTS { ?this a prov:Activity }\r
            }\r
        """ ] .

cdifd:CDIFCatalogRecordShape a sh:NodeShape ;
    sh:message "The target of the metadata record (about)." ;
    sh:nodeKind sh:IRI ;
    sh:property cdifd:catalogRecordTypeProperty,
        cdifd:metadataProfileProperty,
        cdifd:metadataSubjectProperty ;
    sh:target [ a sh:SPARQLTarget ;
            sh:prefixes ( [ sh:namespace "http://schema.org/" ;
                        sh:prefix "schema" ] [ sh:namespace "https://example.org/" ;
                        sh:prefix "ex" ] ) ;
            sh:select """
            PREFIX schema: <http://schema.org/>
            SELECT ?this
            WHERE {
            ?this a schema:Dataset ;
             schema:about ?parent ;
             schema:additionalType "dcat:CatalogRecord" .
            }
        """ ] .

cdifd:CDIFContactPointShape a sh:NodeShape ;
    sh:property [ sh:datatype xsd:string ;
            sh:message "a contact point should be provided; an e-mail address is strongly recommended" ;
            sh:minCount 1 ;
            sh:path schema:email ;
            sh:pattern "[a-z0-9._%+-]+@[a-z0-9.-]+\\.[a-z]{2,}$" ;
            sh:severity sh:Info ] ;
    sh:targetClass schema:ContactPoint .

cdifd:CDIFDataDownloadDetailShape a sh:NodeShape ;
    sh:property [ sh:message "Providers must be specified with either a schema:Person or schema:Organization. If more than one data download option is offered, they can be associated with different providers" ;
            sh:minCount 0 ;
            sh:or ( [ sh:class schema:Person ] [ sh:class schema:Organization ] ) ;
            sh:path schema:provider ],
        [ sh:class spdx:Checksum ;
            sh:message "use the spdx:Checksum class to specify a checksum for a distribution file; at a minimum the checksumValue (string) must be specified" ;
            sh:minCount 0 ;
            sh:path spdx:checksum ;
            sh:property [ sh:datatype xsd:string ;
                    sh:path spdx:algorithm ],
                [ sh:datatype xsd:string ;
                    sh:message "a checksumValue string must be provided in a valid spdx:Checksum instance." ;
                    sh:minCount 1 ;
                    sh:path spdx:checksumValue ] ] ;
    sh:targetClass schema:DataDownload .

cdifd:CDIFDataDownloadShape a sh:NodeShape ;
    sh:message "a datadownload must have a URL that will get the described resource" ;
    sh:property [ sh:datatype xsd:string ;
            sh:minCount 1 ;
            sh:path schema:contentUrl ;
            sh:pattern "^[a-zA-Z][a-zA-Z0-9+.-]*:[^\\s]*$" ] ;
    sh:targetClass schema:DataDownload .

cdifd:CDIFDatasetMandatoryShape a sh:NodeShape ;
    sh:message "A Dataset must have an @id that is a URI (IRI)" ;
    sh:nodeKind sh:IRI ;
    sh:property cdifd:accessProperty,
        cdifd:creatorProperty,
        cdifd:dateModifiedProperty,
        cdifd:descriptionProperty,
        cdifd:keywordsProperty,
        cdifd:nameProperty,
        cdifd:resourceIdentifierProperty,
        cdifd:rightsProperty ;
    sh:target [ a sh:SPARQLTarget ;
            sh:select """
       PREFIX schema: <http://schema.org/>
       PREFIX ex: <https://example.org/>
       PREFIX prov: <http://www.w3.org/ns/prov#>
       PREFIX dcterms: <http://purl.org/dc/terms/>
            SELECT ?this
            WHERE {
              ?this a schema:Dataset .
              # Exclude catalog-record nodes (they describe a record, not a dataset).
              MINUS {
                ?this schema:about ?x .
                ?this schema:additionalType "dcat:CatalogRecord" .
              }
              # Exclude datasets that are only *referenced* as provenance / source /
              # derived-from / based-on resources rather than the resource being
              # documented by this record. Such references carry an @id (and maybe a
              # name/url for readability) but are not held to the full CDIF core
              # requirements - the documented resource is the SUBJECT of provenance,
              # never the object, so this never excludes the documented dataset.
              FILTER NOT EXISTS { ?dpd prov:wasDerivedFrom ?this . }
              FILTER NOT EXISTS { ?dpu prov:used ?this . }
              FILTER NOT EXISTS { ?dib schema:isBasedOn ?this . }
              FILTER NOT EXISTS { ?dsrc dcterms:source ?this . }
            }
          """ ] .

cdifd:CDIFDatasetRecommendedShape a sh:NodeShape ;
    sh:property cdifd:citationProperty,
        cdifd:contributorProperty,
        cdifd:creatorProperty,
        cdifd:datePublishedProperty,
        cdifd:descriptionProperty,
        cdifd:distributionProperty,
        cdifd:keywordsNoCommaTest,
        cdifd:keywordsProperty,
        cdifd:metadataIdentifierProperty,
        cdifd:otherIdentifierProperty,
        cdifd:policiesProperty,
        cdifd:providerProperty,
        cdifd:relatedResourceProperty,
        cdifd:resourceMetadataProfileProperty,
        cdifd:responsiblePartyProperty ;
    sh:target [ a sh:SPARQLTarget ;
            sh:prefixes ( [ sh:namespace "http://schema.org/" ;
                        sh:prefix "schema" ] [ sh:namespace "https://example.org/" ;
                        sh:prefix "ex" ] ) ;
            sh:select """
       PREFIX schema: <http://schema.org/>
       PREFIX ex: <https://example.org/>
            SELECT ?this
            WHERE {
              ?this a schema:Dataset .
              MINUS {
                ?this schema:about ?x .
                ?this schema:additionalType "dcat:CatalogRecord" .
              }
            }
          """ ] .

cdifd:CDIFIdentifierShape a sh:NodeShape ;
    sh:message "identifier rules. for an identifier, the property ID is expected to specify an identifier scheme.Get values from https://registry.identifiers.org/registry/ for interoperability",
        "identifier rules. the context of an identifier, the PropertyValue provides the identifier value string-- either as a schema:value or a url. The value can be either a full URI or identifier token part of URI if a url is provided. url value must be a resolvable URI that identifies the resource." ;
    sh:or ( [ sh:property [ sh:datatype xsd:string ;
                        sh:message "identifier rules. a value for the identifier should be provided; can provide either full URI or identifier token part of URI if a url is provided." ;
                        sh:minCount 1 ;
                        sh:path schema:value ] ] [ sh:property [ sh:datatype xsd:string ;
                        sh:message "identifier rules. schema:url is expected to be a resolvable HTTP URI, but we aren't testing to see if the URL resolves..." ;
                        sh:minCount 1 ;
                        sh:path schema:url ;
                        sh:pattern "^https?:\\/\\/[^\\s]+$" ] ] ) ;
    sh:property [ sh:minCount 1 ;
            sh:or ( [ sh:nodeKind sh:IRI ] [ sh:datatype xsd:string ;
                        sh:minLength 5 ] [ sh:class schema:DefinedTerm ] ) ;
            sh:path schema:propertyID ;
            sh:severity sh:Warning ] ;
    sh:target [ a sh:SPARQLTarget ;
            sh:select """\r
      PREFIX schema: <http://schema.org/>\r
      SELECT DISTINCT ?this\r
        WHERE {\r
        ?this a schema:PropertyValue .\r
        {\r
          ?this schema:propertyID "example identifier" .\r
          FILTER NOT EXISTS { ?s ?p ?this . }\r
        }\r
        Union\r
        {\r
          ?s schema:identifier ?this .\r
        }\r
      }""" ] .

cdifd:CDIFIdentifierTypeTermShape a sh:NodeShape ;
    sh:message "identifier rules. A Term must have a name (label) or an identifier. It should have both!." ;
    sh:property [ sh:message "identifier rules. a defined term should have an identifier that is a resolvable URI" ;
            sh:minCount 1 ;
            sh:or ( [ sh:nodeKind sh:Literal ] [ sh:and ( [ sh:class schema:PropertyValue ] [ sh:or ( [ sh:property [ sh:datatype xsd:string ;
                                                        sh:message "identifier rules. a value for the identifier should be provided; can provide either full URI or identifier token part of URI if a url is provided." ;
                                                        sh:minCount 1 ;
                                                        sh:path schema:value ] ] [ sh:property [ sh:datatype xsd:string ;
                                                        sh:message "identifier rules. value must be a resolvable URL, but we aren't testing to see if the URL resolves..... Can't get xsd:anyURI to work with JSON Schema validation..." ;
                                                        sh:minCount 1 ;
                                                        sh:path schema:url ;
                                                        sh:pattern "^https?:\\/\\/[^\\s]+$" ] ] ) ] ) ] ) ;
            sh:path schema:identifier ] ;
    sh:target [ a sh:SPARQLTarget ;
            sh:prefixes ( [ sh:namespace "http://schema.org/" ;
                        sh:prefix "schema" ] ) ;
            sh:select """\r
      PREFIX schema: <http://schema.org/>\r
      SELECT DISTINCT ?this\r
        WHERE {\r
          ?this a schema:DefinedTerm .\r
          FILTER (\r
            EXISTS { ?s schema:propertyID ?this . }\r
          )\r
        }""" ] .

cdifd:CDIFLabeledLinkShape a sh:NodeShape ;
    sh:property [ sh:datatype xsd:string ;
            sh:message "value must be a resolvable URL, but we aren't testing to see if the URL resolves..... Can't get xsd:anyURI to work with JSON Schema validation..." ;
            sh:minCount 1 ;
            sh:path schema:url ;
            sh:pattern "^https?:\\/\\/[^\\s]+$" ] ;
    sh:targetClass schema:CreativeWork .

cdifd:CDIFOrganizationShape a sh:NodeShape ;
    sh:message "Organization must have an @id IRI, a name or an identifier that is a string" ;
    sh:or ( [ sh:property cdifd:nameProperty ] [ sh:property [ sh:message "an organization should have an identifier that is a URI; use of ORCID is strongly encouraged" ;
                        sh:minCount 1 ;
                        sh:nodeKind sh:IRIOrLiteral ;
                        sh:path schema:identifier ] ] ) ;
    sh:targetClass schema:Organization .

cdifd:CDIFPersonShape a sh:NodeShape ;
    sh:message "A person must have a name or an identifier provided; affiliation to an organization is recommended." ;
    sh:or ( [ sh:property [ sh:message "a person should have an identifier that is a URI; use of ORCID is strongly encouraged" ;
                        sh:minCount 1 ;
                        sh:nodeKind sh:IRIOrLiteral ;
                        sh:path schema:identifier ] ] [ sh:property cdifd:nameProperty ] ) ;
    sh:property cdifd:affiliationProperty,
        cdifd:contactPointProperty ;
    sh:targetClass schema:Person .

cdifd:CDIFRelationShape a sh:NodeShape ;
    sh:message "A cdif:Relation must carry a resolvable schema:url. dcterms:relation (URI of the related resource) and dcat:hadRole (SKOS-typed role) are recommended when the relation distinguishes the related resource from its presentation URL or carries an explicit role." ;
    sh:property [ a sh:PropertyShape ;
            sh:datatype xsd:string ;
            sh:message "cdif:Relation must have at least one schema:url that resolves over http(s)." ;
            sh:minCount 1 ;
            sh:path schema:url ;
            sh:pattern "^https?://[^\\s]+$" ],
        [ a sh:PropertyShape ;
            sh:class skos:Concept ;
            sh:message "If dcat:hadRole is provided, its value must be a skos:Concept classifying the role of the related resource." ;
            sh:path dcat:hadRole ;
            sh:severity sh:Warning ],
        [ a sh:PropertyShape ;
            sh:datatype xsd:string ;
            sh:maxCount 1 ;
            sh:message "If dcterms:relation is provided, it must be a syntactically valid URI." ;
            sh:path dcterms:relation ;
            sh:pattern "^[a-zA-Z][a-zA-Z0-9+.-]*:[^\\s]*$" ;
            sh:severity sh:Warning ],
        [ a sh:PropertyShape ;
            sh:datatype xsd:string ;
            sh:maxCount 1 ;
            sh:path schema:name ],
        [ a sh:PropertyShape ;
            sh:datatype xsd:string ;
            sh:maxCount 1 ;
            sh:path schema:description ] ;
    sh:targetClass dcat:Relationship .

cdifd:CDIFRoleShape a sh:NodeShape ;
    sh:message "The schema.org construct for assigining a role to a contributor nests a second schema:contributor node inside a schema:contributor node." ;
    sh:property [ sh:description "https://cross-domain-interoperability-framework.github.io/cdifbook/metadata/schemaorgimplementation.html" ;
            sh:message "a Role must be filled by a Person, Organization, or IRI reference to one" ;
            sh:minCount 1 ;
            sh:or ( [ sh:class schema:Person ] [ sh:class schema:Organization ] [ sh:nodeKind sh:IRI ] ) ;
            sh:path schema:contributor ],
        cdifd:roleNameProperty ;
    sh:targetClass schema:Role .

cdifd:CDIFVariableMeasuredShape a sh:NodeShape ;
    sh:property [ sh:message "a propertID must be a uri reference, a name string, or a schema:DefinedTerm" ;
            sh:minCount 1 ;
            sh:or ( [ sh:nodeKind sh:IRI ] [ sh:datatype xsd:string ;
                        sh:minLength 5 ] [ sh:class schema:DefinedTerm ;
                        sh:property [ sh:message "a defined term should have an identifier that is a resolvable URI" ;
                                sh:minCount 1 ;
                                sh:or ( [ sh:nodeKind sh:IRI ] [ sh:datatype xsd:string ;
                                            sh:minLength 5 ] [ sh:and ( [ sh:class schema:PropertyValue ] [ sh:or ( [ sh:property [ sh:datatype xsd:string ;
                                                                            sh:message "a value for the definedTerm identifier should be provided; can provide either full URI or identifier token part of URI if a url is provided." ;
                                                                            sh:minCount 1 ;
                                                                            sh:path schema:value ] ] [ sh:property [ sh:datatype xsd:string ;
                                                                            sh:message "value must be a resolvable URL, but we aren't testing to see if the URL resolves..... Can't get xsd:anyURI to work with JSON Schema validation..." ;
                                                                            sh:minCount 1 ;
                                                                            sh:path schema:url ;
                                                                            sh:pattern "^https?:\\/\\/[^\\s]+$" ] ] ) ] ) ] ) ;
                                sh:path schema:identifier ] ] ) ;
            sh:path schema:propertyID ;
            sh:severity sh:Warning ],
        [ sh:datatype xsd:string ;
            sh:message "a variableMeasured should have a text description explaining the variable" ;
            sh:minCount 1 ;
            sh:minLength 10 ;
            sh:path schema:description ;
            sh:severity sh:Info ],
        [ sh:message "measurementTechnique describes how the variable values were determined" ;
            sh:minCount 0 ;
            sh:or ( [ sh:datatype xsd:string ] [ sh:nodeKind sh:IRI ] [ sh:class schema:DefinedTerm ] ) ;
            sh:path schema:measurementTechnique ;
            sh:severity sh:Info ],
        [ sh:datatype xsd:string ;
            sh:message "unitText identifies the unit of measurement as a string" ;
            sh:minCount 0 ;
            sh:path schema:unitText ;
            sh:severity sh:Info ],
        [ sh:message "unitCode identifies the unit of measurement, preferably as a URI from QUDT or similar vocabulary" ;
            sh:minCount 0 ;
            sh:or ( [ sh:datatype xsd:string ] [ sh:nodeKind sh:IRI ] [ sh:class schema:DefinedTerm ] ) ;
            sh:path schema:unitCode ;
            sh:severity sh:Info ],
        [ sh:message "minValue is the minimum numeric value in the dataset for this variable" ;
            sh:minCount 0 ;
            sh:or ( [ sh:datatype xsd:decimal ] [ sh:datatype xsd:integer ] [ sh:datatype xsd:double ] ) ;
            sh:path schema:minValue ;
            sh:severity sh:Info ],
        [ sh:message "maxValue is the maximum numeric value in the dataset for this variable" ;
            sh:minCount 0 ;
            sh:or ( [ sh:datatype xsd:decimal ] [ sh:datatype xsd:integer ] [ sh:datatype xsd:double ] ) ;
            sh:path schema:maxValue ;
            sh:severity sh:Info ],
        cdifd:name3Property,
        cdifd:nameRequiredProperty ;
    sh:target [ a sh:SPARQLTarget ;
            sh:select """\r
      PREFIX schema: <http://schema.org/>\r
      SELECT DISTINCT ?this\r
        WHERE {\r
        ?this a schema:PropertyValue .\r
        {\r
          ?this schema:name "example variable measured" .\r
          FILTER NOT EXISTS { ?s ?p ?this . }\r
        }\r
        Union\r
        {\r
          ?s schema:variableMeasured ?this .\r
        }\r
      }""" ] .

cdifd:derivedFromProperty a sh:NodeShape ;
    sh:filterShape [ sh:nodeKind sh:BlankNode ] ;
    sh:message "PROV:derivedFrom must have a string value, a CreativeWork citing a source or an @id reference to a source." ;
    sh:or ( [ sh:nodeKind sh:IRI ] [ sh:datatype xsd:string ] [ sh:class schema:CreativeWork ;
                sh:property [ sh:datatype xsd:string ;
                        sh:message "value must be a resolvable URL, but we aren't testing to see if the URL resolves..... Can't get xsd:anyURI to work with JSON Schema validation..." ;
                        sh:minCount 1 ;
                        sh:path schema:url ;
                        sh:pattern "^https?:\\/\\/[^\\s]+$" ] ] ) ;
    sh:targetObjectsOf prov:wasDerivedFrom .

cdifd:fundingShape a sh:NodeShape ;
    sh:message "Funding for creation or maintenance of the resource can be acknowledged using schema:MonetaryGrant with at least one of: a funder, an identifier, a name, or a description." ;
    sh:or ( [ sh:property [ sh:minCount 1 ;
                        sh:or ( [ sh:nodeKind sh:IRI ] [ sh:class schema:Person ] [ sh:class schema:Organization ] ) ;
                        sh:path schema:funder ] ] [ sh:property [ sh:message "a monetary Grant should have an identifier that is a resolvable URI" ;
                        sh:minCount 1 ;
                        sh:or ( [ sh:nodeKind sh:IRIOrLiteral ] [ sh:and ( [ sh:class schema:PropertyValue ] [ sh:or ( [ sh:property [ sh:datatype xsd:string ;
                                                                    sh:message "a value for the identifier should be provided; can provide either full URI or identifier token part of URI if a url is provided." ;
                                                                    sh:minCount 1 ;
                                                                    sh:path schema:value ] ] [ sh:property [ sh:datatype xsd:string ;
                                                                    sh:message "value must be a resolvable URL, but we aren't testing to see if the URL resolves..... Can't get xsd:anyURI to work with JSON Schema validation..." ;
                                                                    sh:minCount 1 ;
                                                                    sh:path schema:url ;
                                                                    sh:pattern "^https?:\\/\\/[^\\s]+$" ] ] ) ] ) ] ) ;
                        sh:path schema:identifier ] ] [ sh:property cdifd:grantNameProperty ] [ sh:property [ sh:datatype xsd:string ;
                        sh:minCount 1 ;
                        sh:path schema:description ] ] ) ;
    sh:targetClass schema:MonetaryGrant .

cdifd:generatedByNode a sh:NodeShape ;
    sh:property [ sh:message "The generatedBy Activity should specify at least one resource that was used" ;
            sh:minCount 1 ;
            sh:or ( [ sh:nodeKind sh:IRI ] [ sh:nodeKind sh:BlankNode ] [ sh:datatype xsd:string ;
                        sh:minLength 3 ] ) ;
            sh:path prov:used ;
            sh:severity sh:Warning ] ;
    sh:target [ a sh:SPARQLTarget ;
            sh:select """\r
      PREFIX schema: <http://schema.org/>\r
      PREFIX prov: <http://www.w3.org/ns/prov#>\r
      SELECT DISTINCT ?this\r
        WHERE {\r
        ?this a prov:Activity .\r
        {\r
          ?this schema:name "example generated by" .\r
          FILTER NOT EXISTS { ?s ?p ?this . }\r
        }\r
        Union\r
        {\r
          ?s prov:wasGeneratedBy ?this .\r
        }\r
      }""" ] .

cdifd:maintainerOrProviderContactPointShape a sh:NodeShape ;
    sh:property [ sh:message "A maintainer or provider Person should have a contactPoint for users to reach" ;
            sh:minCount 1 ;
            sh:or ( [ sh:class schema:ContactPoint ] [ sh:nodeKind sh:IRI ] ) ;
            sh:path schema:contactPoint ;
            sh:severity sh:Warning ] ;
    sh:target [ a sh:SPARQLTarget ;
            sh:select """\r
            PREFIX schema: <http://schema.org/>\r
            SELECT ?this WHERE {\r
                { ?record schema:maintainer ?this . }\r
                UNION\r
                { ?record schema:provider ?this . }\r
                ?this a schema:Person .\r
            }\r
        """ ] .

cdifd:qualityMeasurementNode a sh:NodeShape ;
    sh:property [ sh:message "a quality measurement must specify the Measurement test with a name, IRI ref, or Defined Term" ;
            sh:minCount 1 ;
            sh:or ( [ sh:nodeKind sh:IRI ] [ sh:datatype xsd:string ;
                        sh:minLength 3 ] [ sh:class schema:DefinedTerm ] ) ;
            sh:path dqv:isMeasurementOf ],
        [ sh:message "a dataquality measurement must report a result value" ;
            sh:minCount 1 ;
            sh:or ( [ sh:datatype xsd:string ] [ sh:class schema:DefinedTerm ] ) ;
            sh:path dqv:value ] ;
    sh:target [ a sh:SPARQLTarget ;
            sh:select """\r
      PREFIX schema: <http://schema.org/>\r
      PREFIX dqv: <http://www.w3.org/ns/dqv#>\r
      SELECT DISTINCT ?this\r
        WHERE {\r
        ?this a dqv:QualityMeasurement .\r
        {\r
          ?this schema:name "example additional property" .\r
          FILTER NOT EXISTS { ?s ?p ?this . }\r
        }\r
        Union\r
        {\r
          ?s schema:additionalProperty ?this .\r
        }\r
      }""" ] ;
    sh:targetClass dqv:QualityMeasurement .

cdifd:spatialExtentProperty a sh:NodeShape ;
    sh:message "Recommended: provide a spatial coverage description if applicable using schema:Place, identified by a place name, an identifier, point location(s) (GeoCoordinates), or GeoShape (bounding box, line profile location, or polygon)." ;
    sh:or ( [ sh:property [ sh:message "Spatial location MUST be specified either with GeoCoordinates lat/long pairs or with GeoShape Line or Box." ;
                        sh:minCount 1 ;
                        sh:or ( [ sh:node cdifd:geoCoordinatesNode ] [ sh:node cdifd:geoShapeNode ] ) ;
                        sh:path schema:geo ] ] [ sh:property [ sh:minCount 1 ;
                        sh:or ( [ sh:datatype xsd:string ] [ sh:node cdifd:CDIFDefinedTermShape ] ) ;
                        sh:path schema:name ] ] [ sh:property [ sh:minCount 1 ;
                        sh:or ( [ sh:nodeKind sh:IRIOrLiteral ] [ sh:class schema:PropertyValue ] ) ;
                        sh:path schema:identifier ] ] ) ;
    sh:targetClass schema:Place .

cdifd:temporalExtentProperty a sh:PropertyShape ;
    sh:message "temporalCoverage problem; need an ISO 8601 dateTime, ISO 8601 time interval (two xsd:date separated by a '/' character),  or a time:ProperInterval. ISO time interval allows YYYY, YYYY-MM, or YYYY-DD-MM" ;
    sh:minCount 0 ;
    sh:or ( [ sh:class time:ProperInterval ] [ sh:class time:Instant ] [ sh:datatype xsd:string ;
                sh:or ( [ sh:pattern "^[1-2][0-9]{3}-([0][1-9]|[1][0-2])(-([0-2][0-9]|[3][0-1])(T([0-1][0-9]|[2][0-3])(:[0-5][0-9])?(:[0-5][0-9](Z|[+-][0-2][0-9]:[0-5][0-9])?)?)?)?$" ] [ sh:pattern "^(([1-2][0-9]{3}(-([0][1-9]|[1][0-2])(-([0-2][0-9]|[3][0-1]))?)?)|(\\.\\.))\\/([1-2][0-9]{3}(-([0][1-9]|[1][0-2])(-([0-2][0-9]|[3][0-1]))?)?)|(\\.\\.)$" ] ) ] ) ;
    sh:path schema:temporalCoverage .

cdifd:timeInstantNode a sh:NodeShape ;
    sh:property [ sh:class time:TimePosition ;
            sh:message "a time instant must have a TimePosition object as a value" ;
            sh:path time:inTimePosition ] ;
    sh:targetClass time:Instant .

cdifd:timeIntervalNode a sh:NodeShape ;
    sh:property [ sh:class time:Instant ;
            sh:message "A time interval must have a beginning " ;
            sh:minCount 1 ;
            sh:path time:hasBeginning ],
        [ sh:class time:Instant ;
            sh:message "A time interval must have an end " ;
            sh:minCount 1 ;
            sh:path time:hasEnd ] ;
    sh:targetClass time:ProperInterval .

cdifd:timePositionNode a sh:NodeShape ;
    sh:property [ sh:message "include identifier for the temporal reference system as a string or @id with a URI value" ;
            sh:nodeKind sh:IRIOrLiteral ;
            sh:path time:hasTRS ],
        [ sh:message "time position MUST have a numeric value" ;
            sh:or ( [ sh:datatype xsd:integer ] [ sh:datatype xsd:double ] ) ;
            sh:path time:numericPosition ] ;
    sh:targetClass time:TimePosition .

cdifd:webAPINode a sh:NodeShape ;
    sh:property [ sh:message "A WebAPI node must specify a service type with a string, IRI, or DefinedTerm" ;
            sh:minCount 1 ;
            sh:or ( [ sh:nodeKind sh:IRI ] [ sh:class schema:DefinedTerm ] [ sh:datatype xsd:string ;
                        sh:minLength 3 ] ) ;
            sh:path schema:serviceType ],
        [ sh:message "A WebAPI must specify terms of service (schema:termsOfService) as a string, IRI, or CreativeWork." ;
            sh:minCount 1 ;
            sh:or ( [ sh:nodeKind sh:IRI ] [ sh:datatype xsd:string ] [ sh:class schema:CreativeWork ] ) ;
            sh:path schema:termsOfService ],
        [ sh:message "at least one action must be provided for a webAPI distribution" ;
            sh:minCount 1 ;
            sh:or ( [ sh:class schema:Action ] [ sh:class schema:AssessAction ] [ sh:class schema:ConsumeAction ] [ sh:class schema:ControlAction ] [ sh:class schema:CreateAction ] [ sh:class schema:DeleteAction ] [ sh:class schema:FindAction ] [ sh:class schema:InteractAction ] [ sh:class schema:MoveAction ] [ sh:class schema:PlayAction ] [ sh:class schema:SearchAction ] [ sh:class schema:TransferAction ] [ sh:class schema:UpdateAction ] ) ;
            sh:path schema:potentialAction ],
        [ sh:message "a link or URL to a machine-actionable service distribution object should be provided if it exists" ;
            sh:minCount 1 ;
            sh:or ( [ sh:class schema:CreativeWork ] [ sh:nodeKind sh:IRI ] [ sh:datatype xsd:string ] ) ;
            sh:path schema:documentation ;
            sh:severity sh:Info ] ;
    sh:targetClass schema:WebAPI .

<https://www.ogc.org/rules/template/#ConformsToInfo> a sh:NodeShape ;
    sh:property [ sh:message "Recommended: include dcterms:conformsTo to identify the standard or specification this distribution conforms to." ;
            sh:minCount 1 ;
            sh:path dcterms:conformsTo ;
            sh:severity sh:Info ] ;
    sh:targetClass schema:DataDownload .

cdifd:CDIFDefinedTermShape a sh:NodeShape ;
    sh:message "A DefinedTerm must have a name (label), an identifier, OR a termCode. All three are recommended." ;
    sh:or ( [ sh:property [ sh:message "a defined term should have an identifier that is a resolvable URI" ;
                        sh:minCount 1 ;
                        sh:or ( [ sh:datatype xsd:string ] [ sh:and ( [ sh:class schema:PropertyValue ] [ sh:or ( [ sh:property [ sh:datatype xsd:string ;
                                                                    sh:message "a value for the identifier should be provided; can provide either full URI or identifier token part of URI if a url is provided." ;
                                                                    sh:minCount 1 ;
                                                                    sh:path schema:value ] ] [ sh:property [ sh:datatype xsd:string ;
                                                                    sh:message "value expected to be a resolvable http URI, but we aren't testing to see if the URL resolves..." ;
                                                                    sh:minCount 1 ;
                                                                    sh:path schema:url ;
                                                                    sh:pattern "^https?:\\/\\/[^\\s]+$" ] ] ) ] ) ] ) ;
                        sh:path schema:identifier ] ] [ sh:property cdifd:termLabelProperty ] [ sh:property [ sh:datatype xsd:string ;
                        sh:message "a termCode (short code or notation) for the term within its vocabulary" ;
                        sh:minCount 1 ;
                        sh:path schema:termCode ] ] ) ;
    sh:property [ sh:message "inDefinedTermSet identifies the controlled vocabulary from which this term comes; should be a URI or string identifier" ;
            sh:minCount 0 ;
            sh:or ( [ sh:nodeKind sh:IRI ] [ sh:datatype xsd:string ] ) ;
            sh:path schema:inDefinedTermSet ;
            sh:severity sh:Info ],
        [ sh:datatype xsd:string ;
            sh:message "termCode is a short code or notation for the term within its vocabulary (analogous to skos:notation)" ;
            sh:minCount 0 ;
            sh:path schema:termCode ;
            sh:severity sh:Info ] ;
    sh:target [ a sh:SPARQLTarget ;
            sh:select """\r
      PREFIX schema: <http://schema.org/>\r
      SELECT DISTINCT ?this\r
        WHERE {\r
        ?this a schema:DefinedTerm .\r
        {\r
          ?this schema:name "example defined term" .\r
          FILTER NOT EXISTS { ?s ?p ?this . }\r
        }\r
        Union\r
        {\r
         VALUES ?p {\r
            schema:linkRelationship\r
            schema:measurementTechnique\r
            schema:keywords\r
            schema:name\r
          }\r
         ?s ?p ?this .\r
        }\r
      }""" ] .

cdifd:accessProperty a sh:PropertyShape ;
    sh:message "At least one of schema:url (landing page) or schema:distribution (download/API) must be provided for resource access" ;
    sh:minCount 1 ;
    sh:path [ sh:alternativePath ( schema:url schema:distribution ) ] .

cdifd:affiliationProperty a sh:PropertyShape ;
    sh:message "Optional: an affiliation must have object schema:Organization" ;
    sh:minCount 0 ;
    sh:or ( [ sh:class schema:Organization ] [ sh:nodeKind sh:IRI ] ) ;
    sh:path schema:affiliation ;
    sh:severity sh:Warning .

cdifd:catalogRecordTypeProperty a sh:PropertyShape ;
    sh:hasValue "dcat:CatalogRecord" ;
    sh:message "The CatalogRecord node must have schema:additionalType including dcat:CatalogRecord" ;
    sh:minCount 1 ;
    sh:path schema:additionalType .

cdifd:citationProperty a sh:PropertyShape ;
    sh:description "https://cross-domain-interoperability-framework.github.io/cdifbook/metadata/schemaorgimplementation.html" ;
    sh:maxCount 0 ;
    sh:message "schema:citation is not recommended for use in CDIF because of semantic ambiguity. Use dcterms:bibliographicCitation for recommended citation, or schema:relatedLink for related resources." ;
    sh:path schema:citation ;
    sh:severity sh:Info .

cdifd:contactPointProperty a sh:PropertyShape ;
    sh:message "A Person should have a contactPoint (schema:ContactPoint or mailto: IRI)" ;
    sh:minCount 1 ;
    sh:or ( [ sh:class schema:ContactPoint ] [ sh:nodeKind sh:IRI ] ) ;
    sh:path schema:contactPoint ;
    sh:severity sh:Info .

cdifd:contributorProperty a sh:PropertyShape ;
    sh:description "https://cross-domain-interoperability-framework.github.io/cdifbook/metadata/schemaorgimplementation.html" ;
    sh:message "Contributors should be a Role, Person, Organization, or IRI reference to one" ;
    sh:minCount 0 ;
    sh:or ( [ sh:class schema:Role ] [ sh:class schema:Person ] [ sh:class schema:Organization ] [ sh:nodeKind sh:IRI ] ) ;
    sh:path schema:contributor ;
    sh:severity sh:Info .

cdifd:dateModifiedProperty a sh:PropertyShape ;
    sh:datatype xsd:string ;
    sh:message "Date of most recent update to resource content is required, using ISO8601 format with at least a year and a month." ;
    sh:minCount 1 ;
    sh:path schema:dateModified ;
    sh:pattern "^[1-2][0-9]{3}-([0][1-9]|[1][0-2])(-([0-2][0-9]|[3][0-1])(T([0-1][0-9]|[2][0-3])(:[0-5][0-9])?(:[0-5][0-9](Z|[+-][0-2][0-9]:[0-5][0-9])?)?)?)?$" .

cdifd:datePublishedProperty a sh:PropertyShape ;
    sh:datatype xsd:string ;
    sh:message "Please provide a publication or release date, using ISO8601 format with at least a year and a month." ;
    sh:minCount 1 ;
    sh:path schema:datePublished ;
    sh:pattern "^[1-2][0-9]{3}-([0][1-9]|[1][0-2])(-([0-2][0-9]|[3][0-1])(T([0-1][0-9]|[2][0-3])(:[0-5][0-9])?(:[0-5][0-9](Z|[+-][0-2][0-9]:[0-5][0-9])?)?)?)?$" ;
    sh:severity sh:Info .

cdifd:distributionProperty a sh:PropertyShape ;
    sh:message "a schema:distribution must have either a DataDownload or WebAPI value" ;
    sh:minCount 0 ;
    sh:or ( [ sh:class schema:DataDownload ] [ sh:class schema:WebAPI ] ) ;
    sh:path schema:distribution ;
    sh:severity sh:Info .

cdifd:geoCoordinatesNode a sh:NodeShape ;
    sh:message "GeoCoodinates must include latitude between -90 and 90, and longitude between -180 and 180." ;
    sh:property [ sh:maxValue 90.0 ;
            sh:minCount 1 ;
            sh:minValue -90.0 ;
            sh:or ( [ sh:datatype xsd:double ] [ sh:datatype xsd:integer ] ) ;
            sh:path schema:latitude ],
        [ sh:maxValue 180.0 ;
            sh:minCount 1 ;
            sh:minValue -180.0 ;
            sh:or ( [ sh:datatype xsd:double ] [ sh:datatype xsd:integer ] ) ;
            sh:path schema:longitude ] ;
    sh:targetClass schema:GeoCoordinates .

cdifd:geoShapeNode a sh:NodeShape ;
    sh:property [ sh:datatype xsd:string ;
            sh:message "geoshape must include a line or box geometry as a string of latitude longitude pairs" ;
            sh:minCount 1 ;
            sh:path [ sh:alternativePath ( schema:line schema:box ) ] ] ;
    sh:targetClass schema:GeoShape .

cdifd:grantNameProperty a sh:PropertyShape ;
    sh:datatype xsd:string ;
    sh:message "a title for the grant must be provided, and have a length of at least 3 characters." ;
    sh:minCount 1 ;
    sh:minLength 3 ;
    sh:path schema:name .

cdifd:keywordsNoCommaTest a sh:PropertyShape ;
    sh:description "https://cross-domain-interoperability-framework.github.io/cdifbook/metadata/schemaorgimplementation.html" ;
    sh:message "Keywords should be provided as an array of separate values, not a single comma-delimited string; an individual keyword literal MUST NOT contain a comma. If a keyword legitimately contains a comma, express it as a schema:DefinedTerm (with schema:name, and ideally schema:identifier / schema:termCode / schema:inDefinedTermSet) instead of a plain string." ;
    sh:or ( [ sh:datatype xsd:string ;
                sh:pattern "^[^,]*$" ] [ sh:nodeKind sh:BlankNodeOrIRI ] ) ;
    sh:path schema:keywords ;
    sh:severity sh:Warning .

cdifd:metadataIdentifierProperty a sh:PropertyShape ;
    sh:message "The URI for the metadata record should be the @id value for the 'subjectOf' element in the JSON instance document tree or '@id':{uri} in a separate graph node referencing the resource description node" ;
    sh:nodeKind sh:IRI ;
    sh:path schema:subjectOf ;
    sh:severity sh:Warning .

cdifd:metadataProfileProperty a sh:PropertyShape ;
    sh:hasValue <https://w3id.org/cdif/core/1.0>,
        <https://w3id.org/cdif/discovery/1.0> ;
    sh:message "a CDIF Discovery metadata record must declare conformance to both https://w3id.org/cdif/core/1.0 and https://w3id.org/cdif/discovery/1.0" ;
    sh:minCount 1 ;
    sh:nodeKind sh:IRI ;
    sh:path dcterms:conformsTo .

cdifd:metadataSubjectProperty a sh:PropertyShape ;
    sh:message "link to the target of the metadata node using the about property" ;
    sh:minCount 1 ;
    sh:nodeKind sh:IRI ;
    sh:path schema:about .

cdifd:name3Property a sh:PropertyShape ;
    sh:datatype xsd:string ;
    sh:message "variable name is <3 characters, is this name useful?" ;
    sh:minLength 3 ;
    sh:path schema:name ;
    sh:severity sh:Warning .

cdifd:nameRequiredProperty a sh:PropertyShape ;
    sh:datatype xsd:string ;
    sh:message "variableMeasured must have a non-empty schema:name." ;
    sh:minCount 1 ;
    sh:minLength 1 ;
    sh:path schema:name .

cdifd:otherIdentifierProperty a sh:PropertyShape ;
    sh:message "other identifiers for the described resource should be an IRI or literal string" ;
    sh:nodeKind sh:IRIOrLiteral ;
    sh:path schema:sameAs ;
    sh:severity sh:Info .

cdifd:policiesProperty a sh:PropertyShape ;
    sh:message "publication principles and policies must be provided as a schema:CreativeWork, with a schema:name and either a link (schema:url) or a description of the policy" ;
    sh:minCount 0 ;
    sh:or ( [ sh:nodeKind sh:IRI ] [ sh:class schema:CreativeWork ;
                sh:property [ sh:datatype xsd:string ;
                        sh:message "provide a URL linking to a policy statement or a text description of the policy" ;
                        sh:minCount 1 ;
                        sh:path [ sh:alternativePath ( schema:url schema:description ) ] ],
                    [ sh:datatype xsd:string ;
                        sh:message "provide a meaningful label for this policy statement" ;
                        sh:minCount 1 ;
                        sh:path schema:name ;
                        sh:severity sh:Info ] ] ) ;
    sh:path schema:publishingPrinciples ;
    sh:severity sh:Info .

cdifd:providerProperty a sh:PropertyShape ;
    sh:message "if a provider agent is specified it must be either a schema:Person, schema:Organization, or a resolvable URI" ;
    sh:minCount 0 ;
    sh:or ( [ sh:nodeKind sh:IRI ] [ sh:class schema:Person ] [ sh:class schema:Organization ] ) ;
    sh:path schema:provider ;
    sh:severity sh:Info .

cdifd:relatedResourceProperty a sh:PropertyShape ;
    sh:class schema:LinkRole ;
    sh:message "links to related resource use schema:LinkRole, with a linkRelationship (string or IRI), and at least a target schema:url" ;
    sh:minCount 0 ;
    sh:path schema:relatedLink ;
    sh:property [ sh:message "a link to a related resource must specify the relationship to that resource, either with a string label, IRI, or DefinedTerm" ;
            sh:minCount 1 ;
            sh:or ( [ sh:nodeKind sh:IRI ] [ sh:datatype xsd:string ] [ sh:class schema:DefinedTerm ] ) ;
            sh:path schema:linkRelationship ],
        [ sh:class schema:EntryPoint ;
            sh:path schema:target ;
            sh:property [ sh:datatype xsd:string ;
                    sh:path schema:encodingType ],
                [ sh:datatype xsd:string ;
                    sh:path schema:name ],
                [ sh:datatype xsd:string ;
                    sh:message "a URL must be provided for a link to a related resource" ;
                    sh:minCount 1 ;
                    sh:path schema:url ] ] ;
    sh:severity sh:Info .

cdifd:resourceIdentifierProperty a sh:PropertyShape ;
    sh:message "An identifier for the documented resource must be provided" ;
    sh:minCount 1 ;
    sh:or ( [ sh:datatype xsd:string ] [ sh:class schema:PropertyValue ;
                sh:or ( [ sh:property [ sh:datatype xsd:string ;
                                    sh:message "if possible, provide a resolvable URI that will provide a representation of the identified resource." ;
                                    sh:path schema:url ] ] [ sh:property [ sh:datatype xsd:string ;
                                    sh:message "The identifer string; include applicable prefix (e.g. doi:, ark:, http:, isbn:)" ;
                                    sh:path schema:value ] ] ) ;
                sh:property [ sh:datatype xsd:string ;
                        sh:message "If specifying an identifier via the PropertyValue, the scheme (authority, domain) within which the identifier is assigned and unique must be identifed, either by name or preferably using a URI. See https://registry.identifiers.org/registry" ;
                        sh:path schema:propertyID ;
                        sh:severity sh:Warning ] ] ) ;
    sh:path schema:identifier .

cdifd:resourceMetadataProfileProperty a sh:PropertyShape ;
    sh:message "provide identifiers for specifications and datatypes used in this record to provide guidance for machine agents processing the metadata record" ;
    sh:minCount 1 ;
    sh:nodeKind sh:IRIOrLiteral ;
    sh:path ( schema:subjectOf dcterms:conformsTo ) ;
    sh:severity sh:Warning .

cdifd:responsiblePartyProperty a sh:PropertyShape ;
    sh:description "https://cross-domain-interoperability-framework.github.io/cdifbook/metadata/schemaorgimplementation.html" ;
    sh:message "Recommended: identify at least one responsible party as the source authority for the dataset. Options include creator, editor, or publisher." ;
    sh:minCount 1 ;
    sh:path [ sh:alternativePath ( schema:creator schema:editor schema:publisher ) ] ;
    sh:severity sh:Info .

cdifd:rightsProperty a sh:PropertyShape ;
    sh:message "To meet the requirements for FAIR data, information about licenses or other security, usage, or access limitations must be described" ;
    sh:minCount 1 ;
    sh:or ( [ sh:nodeKind sh:IRI ] [ sh:datatype xsd:string ] [ sh:class schema:CreativeWork ;
                sh:property [ sh:datatype xsd:string ;
                        sh:message "value must be a resolvable URL, but we aren't testing to see if the URL resolves..... Can't get xsd:anyURI to work with JSON Schema validation..." ;
                        sh:minCount 1 ;
                        sh:path schema:url ;
                        sh:pattern "^https?:\\/\\/[^\\s]+$" ] ] ) ;
    sh:path [ sh:alternativePath ( schema:license schema:conditionsOfAccess ) ] .

cdifd:roleNameProperty a sh:PropertyShape ;
    sh:message "a Role must provide a roleName, ideally the value is a term from a controlled vocabulary or an IRI for a role concept. For terms from a vocabulary, recommend using schema:DefinedTerm" ;
    sh:minCount 1 ;
    sh:or ( [ sh:datatype xsd:string ] [ sh:class schema:DefinedTerm ] ) ;
    sh:path schema:roleName .

cdifd:termLabelProperty a sh:PropertyShape ;
    sh:datatype xsd:string ;
    sh:message "a label (schema:name) for the term must be provided, and must have at least 3 characters" ;
    sh:minCount 1 ;
    sh:minLength 3 ;
    sh:path schema:name .

cdifd:creatorProperty a sh:PropertyShape ;
    sh:message "At least one creator (author/originator) is recommended" ;
    sh:minCount 1 ;
    sh:path schema:creator ;
    sh:severity sh:Warning .

cdifd:descriptionProperty a sh:PropertyShape ;
    sh:datatype xsd:string ;
    sh:message "A description of the resource is recommended for discovery" ;
    sh:minCount 1 ;
    sh:path schema:description ;
    sh:severity sh:Warning .

cdifd:keywordsProperty a sh:PropertyShape ;
    sh:message "Keywords are recommended for discovery" ;
    sh:minCount 1 ;
    sh:path schema:keywords ;
    sh:severity sh:Warning .

cdifd:nameProperty a sh:PropertyShape ;
    sh:datatype xsd:string ;
    sh:message "a name for the dataset must be provided, and have a length of at least 3 characters." ;
    sh:minCount 1 ;
    sh:minLength 3 ;
    sh:path schema:name .

